global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["127.0.0.1:9090"]
        labels:
          host: "prometheus"
          role: "prometheus"

  - job_name: node_exporter
    static_configs:
{% set monitored = groups['web'] + groups['prometheus_nodes'] + groups['elasticsearch_nodes'] + groups['grafana_nodes'] + groups['kibana_nodes'] %}
{% for host in monitored %}
      - targets: ["{{ hostvars[host].private_ip }}:9100"]
        labels:
          host: "{{ host }}"
          role: "{{ hostvars[host].role | default('node') }}"
{% endfor %}

  - job_name: nginx_log_exporter
    static_configs:
{% for host in groups['web'] %}
      - targets: ["{{ hostvars[host].private_ip }}:4040"]
        labels:
          host: "{{ host }}"
          role: "web"
{% endfor %}
